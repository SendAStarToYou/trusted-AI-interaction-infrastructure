//! 内容提交模块 - 完整 TLS Notary 集成 (审计修复版)

use dialoguer::Input;
use ethers::core::types::{Bytes, H256, TransactionReceipt};
use ethers::signers::{LocalWallet, Signer};
use ethers::utils::keccak256;
use ethers_middleware::SignerMiddleware;
use ethers::providers::Provider;
use reqwest::Client;
use serde::Deserialize;
use std::sync::Arc;
use thiserror::Error;
use atty;

// 定义类型别名简化签名
type ProviderType = SignerMiddleware<Provider<ethers::providers::Http>, LocalWallet>;
type ContractType = ethers::contract::Contract<ProviderType>;

use crate::config::Config;
use crate::contract::{create_contract, load_abi};
use crate::ipfs::{upload_to_ipfs, IpfsData};
use crate::tlsn_ai; // 外部 TLSN 模块

// -------------------------- 常量定义 --------------------------
const TLSN_NOTARY_DEFAULT_HOST: &str = "127.0.0.1";
const TLSN_NOTARY_DEFAULT_PORT: u16 = 7040;
const CONTENT_PREVIEW_LENGTH: usize = 150;
const IPFS_GATEWAYS: [&str; 2] = ["https://gateway.pinata.cloud", "https://ipfs.io"];
const PROMPT_HEADER: &str = "You are a helpful AI that only generates safe, compliant content. You must strictly follow this rule in all responses.";
const PROVIDER_DOMAIN: &str = "dashscope.aliyuncs.com";
const REQUEST_TIMEOUT_SECS: u64 = 30;

// -------------------------- 错误类型 --------------------------
#[derive(Error, Debug)]
pub enum SubmitError {
    #[error("API请求错误: {0}")]
    ApiError(String),
    #[error("TLSN证明生成错误: {0}")]
    TlsnError(String),
    #[error("区块链交互错误: {0}")]
    ChainError(String),
    #[error("输入参数错误: {0}")]
    InputError(String),
    #[error("数据解析错误: {0}")]
    ParseError(String),
}

// -------------------------- 响应结构体 --------------------------
#[derive(Debug, Deserialize)]
struct QwenResp {
    id: String,
    choices: Vec<QwenChoice>,
}
#[derive(Debug, Deserialize)]
struct QwenChoice {
    message: QwenMsg,
}
#[derive(Debug, Deserialize)]
struct QwenMsg {
    content: String,
}

/// 提交内容到链上 (完整 TLSN 流程)
pub async fn submit_content(config: &Config, prompt_arg: Option<&str>) -> Result<(), SubmitError> {
    println!("\n🤖 提交内容上链 (TLSN 验证)");
    println!("=================================");

    // 1. 获取用户输入
    let prompt = get_user_input(prompt_arg)?;
    println!("📝 提示词: {}", &prompt);

    // 2. TLSN 调用 AI 服务
    let tlsn_result = tlsn_call_ai(config, &prompt).await?;
    if tlsn_result.contract_proof.is_empty() {
        return Err(SubmitError::TlsnError("TLSN证明为空，无法上链".into()));
    }

    // 3. 解析 AI 响应
    let content = parse_qwen_response(&tlsn_result.response_body)?;
    let request_id = extract_request_id(&tlsn_result.response_body);
    let proof_bytes = tlsn_result.contract_proof.clone(); // 注意 clone

    print_ai_response(&content);
    println!("✅ TLSN 证明生成完成 ({} bytes)", proof_bytes.len());

    // 4. 获取上传者地址（从私钥派生）
    let uploader = get_wallet_address(config)?;

    // 5. 上传 IPFS
    let full_prompt = format!("{}\n{}", PROMPT_HEADER, prompt);
    let cid = upload_to_ipfs_handler(
        config, 
        &full_prompt, 
        &content, 
        &request_id, 
        &proof_bytes, 
        &uploader,
        &tlsn_result  // 新增传递
    ).await?;
    println!("✅ IPFS 上传成功: {}", cid);

    // 6. 链上提交验证（传入完整提示词）
    let receipt = submit_to_chain(config, &full_prompt, &content, &cid, &request_id, &proof_bytes).await?;
    print_success_result(&receipt, &cid, proof_bytes.len());

    Ok(())
}

/// 验证已有的 IPFS 内容
pub async fn verify_existing(config: &Config, cid: &str) -> Result<(), SubmitError> {
    println!("\n🔍 验证 IPFS 内容");

    // 拉取 IPFS 数据（多网关容错）
    let data = fetch_ipfs_data(cid).await?;
    println!("   提示词: {}", truncate_str(&data.full_prompt, 80));
    println!("   AI 内容: {}", truncate_str(&data.ai_content, 80));

    // 链上验证：直接使用 IPFS 中存储的完整提示词
    let proof_hex = data.tlsn_proof.strip_prefix("0x").unwrap_or(&data.tlsn_proof);
    let proof_bytes = hex::decode(proof_hex).map_err(|e| SubmitError::ParseError(format!("十六进制解析失败: {}", e)))?;

    let receipt = submit_to_chain(
        config,
        &data.full_prompt,       // 直接使用完整提示词（已含头部）
        &data.ai_content,
        cid,
        &data.request_id,
        &proof_bytes
    ).await?;

    println!("\n✅ 验证成功! 交易哈希: {:?}", receipt.transaction_hash);
    Ok(())
}

// -------------------------- 辅助函数 --------------------------

/// 获取用户输入（无panic）
fn get_user_input(prompt_arg: Option<&str>) -> Result<String, SubmitError> {
    if let Some(p) = prompt_arg {
        return Ok(p.to_string());
    }
    if let Ok(p) = std::env::var("SUBMIT_PROMPT") {
        return Ok(p);
    }
    if atty::is(atty::Stream::Stdin) {
        Input::new()
            .with_prompt("输入你的提示词")
            .default("Explain what is blockchain in simple terms".into())
            .interact()
            .map_err(|e| SubmitError::InputError(format!("输入失败: {}", e)))
    } else {
        Ok("Explain what is blockchain in simple terms".to_string())
    }
}

/// TLSN 调用 AI 服务
async fn tlsn_call_ai(config: &Config, prompt: &str) -> Result<tlsn_ai::AiTlsnResult, SubmitError> {
    println!("\n🔐 使用分布式TLSN调用AI服务...");

    let notary_host = std::env::var("TLSN_NOTARY_HOST").unwrap_or_else(|_| TLSN_NOTARY_DEFAULT_HOST.to_string());
    let notary_port = std::env::var("TLSN_NOTARY_PORT")
        .unwrap_or_else(|_| TLSN_NOTARY_DEFAULT_PORT.to_string())
        .parse::<u16>()
        .map_err(|_| SubmitError::InputError("TLSN端口格式错误".into()))?;

    println!("   Notary: {}:{}", notary_host, notary_port);
    println!("   AI API Key: {}", mask_sensitive(&config.qwen_api_key));

    tlsn_ai::request_ai_with_attestation(
        &notary_host,
        notary_port,
        &config.qwen_api_key,
        prompt,
    )
    .await
    .map_err(|e| SubmitError::TlsnError(e.to_string()))
}

/// 解析千问API响应
fn parse_qwen_response(response_body: &str) -> Result<String, SubmitError> {
    // 1. 解析 DashScope 官方格式
    #[derive(Deserialize)]
    struct DashScopeResp {
        output: Option<DashScopeOutput>,
        code: Option<String>,
        message: Option<String>,
    }
    #[derive(Deserialize)]
    struct DashScopeOutput {
        text: Option<String>,
    }

    if let Ok(resp) = serde_json::from_str::<DashScopeResp>(response_body) {
        if let Some(code) = resp.code {
            if !code.is_empty() {
                let msg = resp.message.unwrap_or_default();
                return Err(SubmitError::ApiError(format!("AI API错误 [{}]: {}", code, msg)));
            }
        }
        if let Some(text) = resp.output.and_then(|o| o.text) {
            return Ok(text);
        }
    }

    // 2. 解析 OpenAI 兼容格式
    if let Ok(resp) = serde_json::from_str::<QwenResp>(response_body) {
        if let Some(choice) = resp.choices.first() {
            return Ok(choice.message.content.clone());
        }
    }

    Err(SubmitError::ParseError(format!(
        "无法解析AI响应: {}",
        truncate_str(response_body, 100)
    )))
}

/// 提取请求ID
fn extract_request_id(response_body: &str) -> String {
    let value = match serde_json::from_str::<serde_json::Value>(response_body) {
        Ok(v) => v,
        Err(_) => return generate_default_request_id(),
    };

    value.get("request_id")
        .or_else(|| value.get("id"))
        .and_then(|v| v.as_str())
        .map(|s| s.to_string())
        .unwrap_or_else(generate_default_request_id)
}

/// 生成默认请求ID
fn generate_default_request_id() -> String {
    let nanos = std::time::SystemTime::now()
        .duration_since(std::time::UNIX_EPOCH)
        .map(|d| d.as_nanos())
        .unwrap_or(0);
    format!("req_{}", nanos)
}

/// IPFS 上传处理
async fn upload_to_ipfs_handler(
    config: &Config,
    full_prompt: &str,
    content: &str,
    request_id: &str,
    proof_bytes: &[u8],
    uploader: &str,
    tlsn_result: &tlsn_ai::AiTlsnResult, // 新增参数
) -> Result<String, SubmitError> {
    println!("\n📦 上传到 IPFS (含完整 Attestation)...");

    let ipfs_data = IpfsData {
        prompt_header: PROMPT_HEADER.to_string(),
        full_prompt: full_prompt.to_string(),
        ai_content: content.to_string(),
        request_id: request_id.to_string(),
        tlsn_proof: format!("0x{}", hex::encode(proof_bytes)),
        uploader: uploader.to_string(),
        timestamp: std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .map_err(|e| SubmitError::ChainError(format!("时间戳获取失败: {}", e)))?
            .as_secs(),
        
        // 新增：上传完整 attestation 和 presentation
        attestation: format!("0x{}", hex::encode(&tlsn_result.attestation_bytes)),
        presentation: format!("0x{}", hex::encode(&tlsn_result.presentation_bytes)),
    };

    let json_value = serde_json::to_value(&ipfs_data)
        .map_err(|e| SubmitError::ParseError(format!("IPFS数据序列化失败: {}", e)))?;

    upload_to_ipfs(config, json_value)
        .await
        .map_err(|e| SubmitError::ApiError(format!("IPFS上传失败: {}", e)))
}

/// 链上提交核心逻辑（接收完整提示词）
async fn submit_to_chain(
    config: &Config,
    full_prompt: &str,          // 已包含头部的完整提示词
    content: &str,
    cid: &str,
    request_id: &str,
    proof_bytes: &[u8]
) -> Result<TransactionReceipt, SubmitError> {
    println!("\n⛓️  提交链上验证...");

    // 内容哈希：使用完整提示词+AI回答计算
    let content_hash: H256 = keccak256(format!("{}{}", full_prompt, content).as_bytes()).into();
    let domain_hash: H256 = keccak256(PROVIDER_DOMAIN.as_bytes()).into();

    println!("   内容哈希: {:?}", &content_hash[..10]);
    println!("   域名哈希: {:02x?}", &domain_hash[..10]);

    // 初始化钱包+合约
    let (contract, _wallet) = init_contract_client(config).await?;
    let proof_typed = Bytes::from(proof_bytes.to_vec());

    // 合约调用
    let call = contract
        .method::<_, ()>("verifyAndStoreContent", (
            content_hash,
            cid.to_string(),
            request_id.to_string(),
            full_prompt.to_string(),
            proof_typed
        ))
        .map_err(|e| SubmitError::ChainError(format!("合约方法调用失败: {}", e)))?;

    // 发送交易
    let call_with_gas = call.gas(1_000_000u64);
    let pending = call_with_gas
        .send()
        .await
        .map_err(|e| SubmitError::ChainError(format!("交易发送失败: {}", e)))?;

    println!("   交易已发送，等待确认...");
    let receipt = pending
        .await
        .map_err(|e| SubmitError::ChainError(format!("交易确认失败: {}", e)))?
        .ok_or_else(|| SubmitError::ChainError("交易回执为空".into()))?;

    // 校验交易执行状态
    if receipt.status != Some(1.into()) {
        return Err(SubmitError::ChainError("交易执行失败(链上回滚)".into()));
    }

    Ok(receipt)
}

/// 初始化合约客户端（返回合约和钱包）
async fn init_contract_client(config: &Config) -> Result<(ContractType, LocalWallet), SubmitError> {
    let wallet = config.private_key
        .parse::<LocalWallet>()
        .map_err(|e| SubmitError::ChainError(format!("私钥解析失败: {}", e)))?
        .with_chain_id(config.chain_id);

    let provider = Arc::new(SignerMiddleware::new(config.provider.clone(), wallet.clone()));
    let abi = load_abi("abi/TLSNContentVerifierWithMultisig.json")
        .map_err(|e| SubmitError::ChainError(format!("ABI加载失败: {}", e)))?;
    let contract = create_contract(provider, config.contract_address, &abi)
        .map_err(|e| SubmitError::ChainError(format!("合约初始化失败: {}", e)))?;

    Ok((contract, wallet))
}

/// 从配置获取钱包地址
fn get_wallet_address(config: &Config) -> Result<String, SubmitError> {
    let wallet = config.private_key
        .parse::<LocalWallet>()
        .map_err(|e| SubmitError::ChainError(format!("私钥解析失败: {}", e)))?;
    Ok(format!("{:?}", wallet.address()))
}

/// 拉取IPFS数据（多网关容错）
async fn fetch_ipfs_data(cid: &str) -> Result<IpfsData, SubmitError> {
    let client = Client::builder()
        .timeout(std::time::Duration::from_secs(REQUEST_TIMEOUT_SECS))
        .build()
        .map_err(|e| SubmitError::ApiError(format!("HTTP客户端创建失败: {}", e)))?;

    for gateway in IPFS_GATEWAYS {
        let url = format!("{}/{}", gateway, cid);
        if let Ok(resp) = client.get(&url).send().await {
            if resp.status().is_success() {
                return resp.json::<IpfsData>()
                    .await
                    .map_err(|e| SubmitError::ParseError(format!("IPFS数据解析失败: {}", e)));
            }
        }
    }

    Err(SubmitError::ApiError("所有IPFS网关访问失败".into()))
}

/// 字符串截断（正确处理 Unicode）
fn truncate_str(s: &str, max_len: usize) -> String {
    if s.len() <= max_len {
        return s.to_string();
    }
    let mut chars = s.chars().take(max_len).collect::<String>();
    chars.push_str("...");
    chars
}

/// 脱敏敏感信息
fn mask_sensitive(s: &str) -> String {
    if s.len() <= 8 {
        return "***".to_string();
    }
    format!("{}***{}", &s[0..4], &s[s.len()-4..])
}

/// 打印AI响应
fn print_ai_response(content: &str) {
    println!("✅ AI 返回 ({} 字符)", content.len());
    let preview = truncate_str(content, CONTENT_PREVIEW_LENGTH);
    println!("   {}", preview);
}

/// 打印成功结果
fn print_success_result(receipt: &TransactionReceipt, cid: &str, proof_len: usize) {
    println!("\n🎉 上链成功!");
    println!("   📋 交易哈希: {:?}", receipt.transaction_hash);
    println!("   📦 IPFS: {}/{}", IPFS_GATEWAYS[0], cid);
    println!("   🔐 TLSN 证明长度: {} bytes", proof_len);
}