# ==================== 区块链配置 ====================
INFURA_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
PRIVATE_KEY=YOUR_TESTNET_PRIVATE_KEY
CONTRACT_ADDRESS=YOUR_DEPLOYED_CONTRACT_ADDRESS
CHAIN_ID=11155111  # Sepolia=11155111 Mumbai=80001

# ==================== IPFS Pinata ====================
PINATA_API_KEY=YOUR_PINATA_API_KEY
PINATA_SECRET=YOUR_PINATA_SECRET

# ==================== 阿里通义千问 (OpenAI兼容) ====================
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-turbo

# ==================== TLS Notary ====================
TLSN_NOTARY_HOST=notary.tlsn.io
TLSN_NOTARY_PORT=443

# ==================== 多签管理员 (3个) ====================
ADMIN_ADDRESSES=0xAddr1,0xAddr2,0xAddr3
ADMIN1_PRIVATE_KEY=ADMIN1_PRIVATE_KEY
ADMIN2_PRIVATE_KEY=ADMIN2_PRIVATE_KEY
ADMIN3_PRIVATE_KEY=ADMIN3_PRIVATE_KEY